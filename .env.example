# ============================================================
# MentorTI Nexus - Variables de entorno (plantilla)
# Copiar a .env y completar los valores. NUNCA versionar .env
# ============================================================

# --- LLM: OpenRouter (https://openrouter.ai) ---
OPENROUTER_API_KEY=<OPENROUTER_API_KEY>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemma-4-26b-a4b-it:free
LLM_TEMPERATURE=0.2
FALLBACK_LLM_MODELS=nvidia/nemotron-3-nano-30b-a3b:free,tencent/hy3:free

# --- Embeddings remotos (HuggingFace Inference API) ---
# Obtén tu token gratis en https://huggingface.co/settings/tokens
# Sin token funciona con rate limits reducidos (suficiente para desarrollo)
HUGGINGFACE_API_KEY=<HUGGINGFACE_API_KE>
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Rutas de datos ---
FAISS_INDEX_PATH=data/faiss_index
RAW_DOCS_PATH=data/raw

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
RETRIEVER_K=4
SCORE_THRESHOLD=0.25

# --- CORS (producción) ---
# Separar múltiples orígenes por coma
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Aplicación ---
APP_NAME=MentorTI Nexus
APP_DEFAULT_LANG=es
